{
  "name": "coffee-manager",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter api exec prisma generate",
    "db:migrate": "pnpm --filter api exec prisma migrate dev",
    "db:seed": "pnpm --filter api exec prisma db seed"
  },
  "devDependencies": {
    "turbo": "^2.1.3"
  }
}
