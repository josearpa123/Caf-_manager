FROM node:22-alpine AS base
RUN corepack enable
WORKDIR /repo

FROM base AS deps
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml* ./
COPY apps/web/package.json apps/web/package.json
COPY packages packages
RUN pnpm install --frozen-lockfile --filter web...

FROM deps AS build
# NEXT_PUBLIC_* se hornea en el bundle EN BUILD-TIME: el navegador del usuario
# usa esta URL para llamar a la API, así que debe apuntar al host público, no a
# localhost. Se pasa como build-arg desde docker-compose.prod.yml.
ARG NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
COPY apps/web apps/web
RUN pnpm --filter web build

FROM base AS runtime
ENV NODE_ENV=production
# Copiamos el árbol /repo completo: pnpm enlaza node_modules por symlinks al
# store (.pnpm) y a los packages del workspace, así que copiar solo apps/web
# dejaría enlaces colgando. Copiar /repo entero mantiene todo resuelto.
COPY --from=build /repo /repo
WORKDIR /repo/apps/web
EXPOSE 3000
CMD ["node_modules/.bin/next", "start"]
