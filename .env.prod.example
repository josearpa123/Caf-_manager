# =============================================================================
# Coffee Manager — variables de PRODUCCIÓN (piloto)
# =============================================================================
# Copia este archivo a `.env.prod` y rellena los valores:
#     cp .env.prod.example .env.prod
# `.env.prod` está gitignoreado: NUNCA lo subas al repo.
#
# Genera secretos fuertes con:
#     openssl rand -base64 32
# =============================================================================

# ---- Base de datos PostgreSQL -----------------------------------------------
POSTGRES_USER=coffee
POSTGRES_PASSWORD=CAMBIA_ESTA_CLAVE_por_una_larga_y_aleatoria
POSTGRES_DB=coffee_manager

# ---- Secretos JWT (usa `openssl rand -base64 32` para cada uno) --------------
JWT_ACCESS_SECRET=CAMBIA_access_secret
JWT_ACCESS_EXPIRES_IN=30m
JWT_PLATFORM_SECRET=CAMBIA_platform_secret
JWT_PLATFORM_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN_DAYS=30

# ---- Super-admin de plataforma (se crea solo en el primer arranque) ---------
# Con este usuario entras a /platform/login para aprobar los registros de tenants.
PLATFORM_ADMIN_EMAIL=admin@tudominio.com
PLATFORM_ADMIN_PASSWORD=CAMBIA_una_clave_fuerte
PLATFORM_ADMIN_NOMBRE=Administrador

# ---- URL pública de la API (se hornea en el frontend en build-time) ---------
# El NAVEGADOR de tus usuarios usa esta URL. Debe ser accesible desde internet.
#
#   Opción A · solo IP (más rápido, sin HTTPS):   http://<IP_PUBLICA_DE_LA_VM>:3001
#   Opción B · con dominio + HTTPS (Caddy):        https://api.tudominio.duckdns.org
#
# Si cambias este valor hay que RECONSTRUIR el front (--build).
NEXT_PUBLIC_API_URL=http://CAMBIA_LA_IP_PUBLICA:3001
